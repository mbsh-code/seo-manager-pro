{
  "name": "seo-manager-pro",
  "version": "26.6.20",
  "description": "SEO + AEO manager for Angular, React, Vue and Vanilla JS — search engines and AI answer engines.",
  "main": "dist/seo-manager-pro.js",
  "types": "dist/seo-manager-pro.d.ts",
  "exports": {
    ".": {
      "types": "./dist/seo-manager-pro.d.ts",
      "default": "./dist/seo-manager-pro.js"
    },
    "./seo": {
      "types": "./dist/seo/seo-manager.d.ts",
      "default": "./dist/seo/seo-manager.js"
    },
    "./aeo": {
      "types": "./dist/aeo/aeo-manager.d.ts",
      "default": "./dist/aeo/aeo-manager.js"
    }
  },
  "files": [
    "dist/",
    "README.md",
    "llms.txt",
    "LICENSE.txt"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "SEO",
    "AEO",
    "GEO",
    "AI",
    "llms.txt",
    "Meta",
    "Schema",
    "Angular",
    "React",
    "Vue",
    "typescript",
    "seo-manager",
    "answer-engine-optimization"
  ],
  "author": "MohammadBagher Sharifi",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mbsh-code/seo-manager-pro.git"
  }
}
